# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local example: mongodb://127.0.0.1:27017/restaurant-reservations
# Atlas example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/restaurant-reservations
MONGO_URI=mongodb+srv://Restaurant_Admin:Heyy@cluster0.vmo260y.mongodb.net/restaurant-reservations?retryWrites=true&w=majority

# JWT
JWT_SECRET=Mantra_to_perfectly_deploy_the_app
JWT_EXPIRES_IN=30d

# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# Used by utils/seed.js to create the first admin account
ADMIN_EMAIL=admin@restaurant.com
ADMIN_PASSWORD=Heyy
ADMIN_NAME=Restaurant_Admin
